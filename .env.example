# ── Google Sheets (Service Account) ──────────────────────────────────────────
# Step-by-step setup: see README.md

# From your downloaded service-account JSON → "client_email"
GOOGLE_CLIENT_EMAIL=upsc-diagnostic@your-project-id.iam.gserviceaccount.com

# From your downloaded service-account JSON → "private_key"
# Paste the full key including -----BEGIN ... END----- lines
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nXXXXX\n-----END RSA PRIVATE KEY-----\n"

# Spreadsheet ID from the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Name of the tab inside the sheet (default: Responses)
GOOGLE_SHEET_TAB=Responses
